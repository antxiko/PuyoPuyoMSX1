                                    388 ; Check for skip key press
                                    389 ;------------------------------------------------------------------------------
                                    390 .macro SKIP_BOOT
                                    391 	.if ROM_SKIP
                                    392 	; Check for 'ESC' key press
                                    393 	ctr0_check_rom_skip:
                                    394 		in		a, (PPI_C)
                                    395 		and		#0xF0					; only change bits 0-3
                                    396 		or		#7						; check row number 7
                                    397 		out		(PPI_C), a
                                    398 		in		a, (PPI_B)				; read row into A
                                    399 		and		#ROM_SKIP_KEY
                                    400 		ret		z
                                    401 	.endif
                                    402 .endm
